# optional per-machine overrides: .env.local, .env.development.local, .env.test.local
APP_PORT=8080
APP_ENV=development
# optional: debug|info|warn|error (empty = non-production defaults to debug, production defaults to info)
LOG_LEVEL=

# go app logs web ui (Grafana + Loki)
GRAFANA_PORT=3000
LOKI_PORT=3100
LOKI_HOST=host.docker.internal
LOKI_PUSH_URL=http://host.docker.internal:3100/loki/api/v1/push

# local dev-env compose helpers
ZITADEL_PORT=18081
ZITADEL_DOMAIN=localhost
ZITADEL_VERSION=v4.11.0
ZITADEL_MASTERKEY=MasterkeyNeedsToHave32Characters
ZITADEL_FIRSTINSTANCE_ORG_NAME=sekai
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_USERNAME=admin
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_PASSWORD=Admin123!Admin123!
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_EMAIL_ADDRESS=admin@sekai.local
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_EMAIL_VERIFIED=true
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_FIRSTNAME=Sekai
ZITADEL_FIRSTINSTANCE_ORG_HUMAN_LASTNAME=Admin
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINE_USERNAME=sekai-bootstrap
ZITADEL_FIRSTINSTANCE_ORG_MACHINE_MACHINE_NAME="Sekai Bootstrap Admin"
ZITADEL_BOOTSTRAP_PROJECT_NAME=sekai-local
ZITADEL_BOOTSTRAP_APP_NAME=sekai-admin-web

# optional database driver override: sqlite | pgx
DATABASE_DRIVER=

# sqlite for development
SQLITE_PATH=./tmp/dev.db

# postgresql for test/production
DATABASE_URL=postgres://sekai:sekai@localhost:5432/sekai?sslmode=disable

# master data sync
MASTER_DATA_AUTO_SYNC=true
MASTER_DATA_SYNC_TIMEOUT_SECONDS=120
MASTER_DATA_SYNC_CONCURRENCY=4
MASTER_DATA_REGION_FILE_CONCURRENCY=8
MASTER_DATA_HTTP_TIMEOUT_SECONDS=20
MASTER_DATA_HTTP_RETRY_COUNT=3
MASTER_DATA_HTTP_RETRY_BACKOFF_MS=300
MASTER_DATA_GITHUB_TOKEN=
MASTER_DATA_REGIONS=jp,global

# master data source per region
MASTER_DATA_GITHUB_OWNER_JP=Sekai-World
MASTER_DATA_GITHUB_REPO_JP=sekai-master-data-jp
MASTER_DATA_GITHUB_REF_JP=main
MASTER_DATA_GITHUB_PATH_JP=data

MASTER_DATA_GITHUB_OWNER_GLOBAL=Sekai-World
MASTER_DATA_GITHUB_REPO_GLOBAL=sekai-master-data-global
MASTER_DATA_GITHUB_REF_GLOBAL=main
MASTER_DATA_GITHUB_PATH_GLOBAL=data

# redis (required for master-data id cache)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
MASTER_DATA_REDIS_KEY_PREFIX=sekai:master-data:

# zitadel
# dev-env-up writes generated local client/project values to .env.development.local
ZITADEL_ISSUER_URL=http://localhost:18081
ZITADEL_INTERNAL_URL=
ZITADEL_AUDIENCE=
ZITADEL_SKIP_ISSUER_CHECK=false
ZITADEL_SKIP_AUDIENCE_CHECK=false
ZITADEL_CLIENT_ID=
ZITADEL_AUTH_URL=http://localhost:18081/oauth/v2/authorize
ZITADEL_TOKEN_URL=http://localhost:18081/oauth/v2/token
ZITADEL_REDIRECT_URL=http://localhost:8080/api/v1/admin/login/callback
ZITADEL_SCOPES=openid,profile,email
ZITADEL_PRIVATE_KEY_PATH=
ZITADEL_PRIVATE_KEY_ID=
