APP_PORT=8080
APP_ENV=development
# optional: debug|info|warn|error (empty = non-production defaults to debug, production defaults to info)
LOG_LEVEL=

# go app logs web ui (Grafana + Loki)
GRAFANA_PORT=3000
LOKI_PORT=3100
LOKI_HOST=host.docker.internal
LOKI_PUSH_URL=http://host.docker.internal:3100/loki/api/v1/push

# optional database driver override: sqlite | pgx
DATABASE_DRIVER=

# sqlite for development
SQLITE_PATH=./tmp/dev.db

# postgresql for test/production
DATABASE_URL=postgres://sekai:sekai@localhost:5432/sekai?sslmode=disable

# master data sync
MASTER_DATA_AUTO_SYNC=true
MASTER_DATA_SYNC_TIMEOUT_SECONDS=120
MASTER_DATA_SYNC_CONCURRENCY=4
MASTER_DATA_REGION_FILE_CONCURRENCY=8
MASTER_DATA_HTTP_TIMEOUT_SECONDS=20
MASTER_DATA_HTTP_RETRY_COUNT=3
MASTER_DATA_HTTP_RETRY_BACKOFF_MS=300
MASTER_DATA_GITHUB_TOKEN=
MASTER_DATA_REGIONS=jp,global

# master data source per region
MASTER_DATA_GITHUB_OWNER_JP=Sekai-World
MASTER_DATA_GITHUB_REPO_JP=sekai-master-data-jp
MASTER_DATA_GITHUB_REF_JP=main
MASTER_DATA_GITHUB_PATH_JP=data

MASTER_DATA_GITHUB_OWNER_GLOBAL=Sekai-World
MASTER_DATA_GITHUB_REPO_GLOBAL=sekai-master-data-global
MASTER_DATA_GITHUB_REF_GLOBAL=main
MASTER_DATA_GITHUB_PATH_GLOBAL=data

# redis (required for master-data id cache)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
MASTER_DATA_REDIS_KEY_PREFIX=sekai:master-data:

# keycloak
KEYCLOAK_ISSUER_URL=http://localhost:8081/realms/sekai
KEYCLOAK_AUDIENCE=sekai-api
KEYCLOAK_SKIP_ISSUER_CHECK=false
KEYCLOAK_SKIP_AUDIENCE_CHECK=false

# keycloak local helper script defaults
KEYCLOAK_BASE_URL=http://localhost:8081
KEYCLOAK_REALM=sekai
KEYCLOAK_CLIENT_ID=sekai-api
KEYCLOAK_USERNAME=alice
KEYCLOAK_PASSWORD=alice123!
