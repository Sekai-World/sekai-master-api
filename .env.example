# optional per-machine overrides: .env.local, .env.development.local, .env.test.local
COMPOSE_PROJECT_NAME=sekai-master-api
APP_PORT=18080
APP_ENV=development
# optional: debug|info|warn|error (empty = non-production defaults to debug, production defaults to info)
LOG_LEVEL=

# go app logs web ui (Grafana + Loki)
GRAFANA_PORT=13000
LOKI_PORT=3100
LOKI_HOST=host.docker.internal
LOKI_PUSH_URL=http://host.docker.internal:3100/loki/api/v1/push
PROMETHEUS_PORT=9090
TEMPO_PORT=3200
ALLOY_OTLP_GRPC_PORT=4317
ALLOY_OTLP_HTTP_PORT=4318

# OpenTelemetry tracing + metrics
OTEL_ENABLED=true
OTEL_SERVICE_NAME=sekai-master-api
OTEL_SERVICE_VERSION=
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_METRIC_EXPORT_INTERVAL=10000

# optional database driver override: sqlite | pgx
DATABASE_DRIVER=

# sqlite for development
SQLITE_PATH=./tmp/dev.db

# local keycloak dev-env
KEYCLOAK_PORT=18081
KEYCLOAK_VERSION=26.5.4
KEYCLOAK_BASE_URL=http://localhost:18081
KEYCLOAK_REALM=sekai
KEYCLOAK_CLIENT_ID=sekai-api
KEYCLOAK_USERNAME=alice
KEYCLOAK_PASSWORD=alice123!
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# postgresql for test/production
DATABASE_URL=postgres://sekai:sekai@localhost:5432/sekai?sslmode=disable

# master data sync
MASTER_DATA_AUTO_SYNC=true
MASTER_DATA_RECOVER_INTERRUPTED_SYNC=true
MASTER_DATA_WARM_SEARCH_INDEXES=false
MASTER_DATA_SEARCH_INDEX_CACHE_ENTRIES=32
MASTER_DATA_SYNC_TIMEOUT_SECONDS=120
MASTER_DATA_SYNC_CONCURRENCY=1
MASTER_DATA_REGION_FILE_CONCURRENCY=2
MASTER_DATA_HTTP_TIMEOUT_SECONDS=20
MASTER_DATA_HTTP_RETRY_COUNT=3
MASTER_DATA_HTTP_RETRY_BACKOFF_MS=300
MASTER_DATA_GITHUB_TOKEN=
# Required to enable GitHub webhook sync; empty disables the webhook endpoint.
MASTER_DATA_GITHUB_WEBHOOK_SECRET=
MASTER_DATA_REGIONS=jp,global

# master data source per region
MASTER_DATA_GITHUB_OWNER_JP=Sekai-World
MASTER_DATA_GITHUB_REPO_JP=sekai-master-data-jp
MASTER_DATA_GITHUB_REF_JP=main
MASTER_DATA_GITHUB_PATH_JP=data

MASTER_DATA_GITHUB_OWNER_GLOBAL=Sekai-World
MASTER_DATA_GITHUB_REPO_GLOBAL=sekai-master-data-global
MASTER_DATA_GITHUB_REF_GLOBAL=main
MASTER_DATA_GITHUB_PATH_GLOBAL=data

# redis (required for master-data id cache)
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
MASTER_DATA_REDIS_KEY_PREFIX=sekai:master-data:

# oidc provider
OIDC_ISSUER_URL=http://localhost:18081/realms/sekai
OIDC_INTERNAL_URL=http://host.docker.internal:18081/realms/sekai
OIDC_AUDIENCE=sekai-api
OIDC_SKIP_ISSUER_CHECK=false
OIDC_SKIP_AUDIENCE_CHECK=false
OIDC_CLIENT_ID=sekai-api
OIDC_AUTH_URL=
OIDC_TOKEN_URL=
OIDC_REDIRECT_URL=http://localhost:18080/api/v1/admin/login/callback
OIDC_SCOPES=openid,profile,email
OIDC_PRIVATE_KEY_PATH=
OIDC_PRIVATE_KEY_ID=
OIDC_ADMIN_CLAIM=groups
OIDC_ADMIN_CLAIM_VALUES=sekai-admin
