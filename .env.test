APP_PORT=18080
APP_ENV=test

# deployed test server PostgreSQL
DATABASE_URL=postgres://sekai:sekai@test-db.example.com:5432/sekai?sslmode=disable

# oidc provider
OIDC_ISSUER_URL=https://keycloak-test.example.com/realms/sekai
OIDC_AUDIENCE=sekai-api
OIDC_SKIP_ISSUER_CHECK=false
OIDC_SKIP_AUDIENCE_CHECK=false
OIDC_CLIENT_ID=replace-with-web-client-id
OIDC_AUTH_URL=https://keycloak-test.example.com/realms/sekai/protocol/openid-connect/auth
OIDC_TOKEN_URL=https://keycloak-test.example.com/realms/sekai/protocol/openid-connect/token
OIDC_REDIRECT_URL=https://api-test.example.com/api/v1/admin/login/callback
OIDC_SCOPES=openid,profile,email
OIDC_PRIVATE_KEY_PATH=./deploy/credentials/oidc-admin-web.pem
OIDC_PRIVATE_KEY_ID=replace-with-private-key-id
OIDC_ADMIN_CLAIM=groups
OIDC_ADMIN_CLAIM_VALUES=sekai-admin
