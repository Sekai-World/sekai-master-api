APP_PORT=8080
APP_ENV=test

# deployed test server PostgreSQL
DATABASE_URL=postgres://sekai:sekai@test-db.example.com:5432/sekai?sslmode=disable

# zitadel
ZITADEL_ISSUER_URL=https://zitadel-test.example.com
ZITADEL_AUDIENCE=https://api-test.example.com
ZITADEL_SKIP_ISSUER_CHECK=false
ZITADEL_SKIP_AUDIENCE_CHECK=false
ZITADEL_CLIENT_ID=replace-with-web-client-id
ZITADEL_AUTH_URL=https://zitadel-test.example.com/oauth/v2/authorize
ZITADEL_TOKEN_URL=https://zitadel-test.example.com/oauth/v2/token
ZITADEL_REDIRECT_URL=https://api-test.example.com/api/v1/admin/login/callback
ZITADEL_SCOPES=openid,profile,email,urn:zitadel:iam:org:project:id:replace-with-project-id:aud
ZITADEL_PRIVATE_KEY_PATH=./deploy/credentials/zitadel-admin-web.pem
ZITADEL_PRIVATE_KEY_ID=replace-with-private-key-id
