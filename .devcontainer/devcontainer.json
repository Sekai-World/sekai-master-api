{
  "name": "sekai-master-api-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "containerEnv": {
    "DOCKER_HOST": "unix:///var/run/docker.sock",
    "CGO_ENABLED": "0",
    "SSH_AUTH_SOCK": "/tmp/ssh-agent.sock"
  },
  "runArgs": [
    "--group-add=${localEnv:DOCKER_SOCK_GID:0}"
  ],
  "mounts": [
    "source=${localEnv:DOCKER_SOCK_PATH:/var/run/docker.sock},target=/var/run/docker.sock,type=bind",
    "source=${localEnv:SSH_AUTH_SOCK:/run/host-services/ssh-auth.sock},target=/tmp/ssh-agent.sock,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "GitHub.vscode-github-actions",
        "mtxr.sqltools",
        "DavidAnson.vscode-markdownlint",
        "piotrpalarz.vscode-gitignore-generator",
        "IronGeek.vscode-env",
        "mtxr.sqltools-driver-pg"
      ]
    }
  },
  "postCreateCommand": "bash -lc 'set -euo pipefail; command -v codex >/dev/null 2>&1 || npm install -g @openai/codex; mkdir -p ~/.codex ~/.ssh; chmod 700 ~/.ssh; ln -sf /workspaces/sekai-master-api/.devcontainer/config.toml ~/.codex/config.toml; go mod tidy'"
}
