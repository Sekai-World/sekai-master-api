{
  "name": "sekai-master-api-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "containerEnv": {
    "DOCKER_HOST": "unix:///var/run/docker-host.sock",
    "CONTAINER_HOST": "unix:///var/run/docker-host.sock",
    "CGO_ENABLED": "0"
  },
  "runArgs": [
    "--group-add=${localEnv:PODMAN_SOCK_GID:0}"
  ],
  "mounts": [
    "source=${localEnv:PODMAN_SOCK_PATH:/var/run/docker.sock},target=/var/run/docker-host.sock,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "ms-azuretools.vscode-docker",
        "GitHub.vscode-github-actions",
        "mtxr.sqltools",
        "DavidAnson.vscode-markdownlint",
        "piotrpalarz.vscode-gitignore-generator",
        "IronGeek.vscode-env",
        "mtxr.sqltools-driver-pg"
      ]
    }
  },
  "postCreateCommand": "go mod tidy"
}
