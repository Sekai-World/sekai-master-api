{
  "name": "sekai-master-api-dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    }
  },
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "containerEnv": {
    "CONTAINER_HOST": "unix:///var/run/podman-host.sock",
    "CGO_ENABLED": "0"
  },
  "runArgs": [
    "--group-add=${localEnv:PODMAN_SOCK_GID:0}"
  ],
  "mounts": [
    "source=${localEnv:PODMAN_SOCK_PATH:/run/user/1000/podman/podman.sock},target=/var/run/podman-host.sock,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "GitHub.vscode-github-actions",
        "mtxr.sqltools",
        "DavidAnson.vscode-markdownlint",
        "piotrpalarz.vscode-gitignore-generator",
        "IronGeek.vscode-env",
        "mtxr.sqltools-driver-pg"
      ]
    }
  },
  "postCreateCommand": "bash -lc 'set -euo pipefail; command -v codex >/dev/null 2>&1 || npm install -g @openai/codex; mkdir -p ~/.codex; ln -sf /workspaces/sekai-master-api/.devcontainer/config.toml ~/.codex/config.toml; go mod tidy'"
}
