#!/usr/bin/env sh
set -eu

. ./.mise/lib/tasks.sh
load_defaults

echo "[dev] ensuring dependency stack is running"
mise run --skip-tools dev-env-up

docker_bin="${DOCKER}"
dev_image="${DEV_APP_IMAGE}"
dev_container="${DEV_APP_CONTAINER}"
dev_network="${DEV_APP_NETWORK}"
dev_volume="${DEV_APP_VOLUME}"
app_port="${APP_PORT}"
internal_port="${DEV_APP_INTERNAL_PORT}"

echo "[dev] building app image ${dev_image} with buildx"
"$docker_bin" buildx build --load -f deploy/compose/app/Dockerfile -t "$dev_image" .

echo "[dev] recreating container ${dev_container} on network ${dev_network}"
"$docker_bin" rm -f "$dev_container" >/dev/null 2>&1 || true
"$docker_bin" volume create "$dev_volume" >/dev/null
"$docker_bin" run -d \
  --name "$dev_container" \
  --restart unless-stopped \
  --network "$dev_network" \
  -e DEV_HOST_APP_PORT="$app_port" \
  -e DEV_MASTER_DATA_AUTO_SYNC="${DEV_MASTER_DATA_AUTO_SYNC}" \
  -e DEV_MASTER_DATA_RECOVER_INTERRUPTED_SYNC="${DEV_MASTER_DATA_RECOVER_INTERRUPTED_SYNC}" \
  -p "${app_port}:${internal_port}" \
  -v "${dev_volume}:/app/tmp" \
  "$dev_image" >/dev/null

echo "[dev] app listening on http://localhost:${app_port}"
echo "[dev] MASTER_DATA_AUTO_SYNC=${DEV_MASTER_DATA_AUTO_SYNC}"
echo "[dev] MASTER_DATA_RECOVER_INTERRUPTED_SYNC=${DEV_MASTER_DATA_RECOVER_INTERRUPTED_SYNC}"
echo "[dev] logs: mise run dev-logs"
